# Клиентские переменные (попадают в бандл — публиковать безопасно)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Серверные переменные (для SSR / edge — НЕ публиковать service_role)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API-ключ Stadia Maps для подложки (стиль Alidade Smooth).
# Регистрация: https://client.stadiamaps.com/signup/ (free tier 200k/мес).
# Одна Property = один домен в Authentication Configuration.
# Заводим одну Property под metrics.datatells.info и берём ключ оттуда.
# На localhost и *.lovable.app ключ не нужен (dev-whitelist Stadia).
# В проде ключ кладётся через Lovable Cloud → Secrets как VITE_STADIA_API_KEY.
# Инструкция: docs/self-hosted-basemap-setup.md
VITE_STADIA_API_KEY=your-stadia-api-key
