# Клиентские переменные (попадают в бандл — публиковать безопасно)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Серверные переменные (для SSR / edge — НЕ публиковать service_role)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Базовый URL для самохостинговой подложки (Protomaps + Cloudflare R2).
# По этому пути должны лежать /georgia.pmtiles, /fonts/, /sprites/.
# Обычно это публичный URL R2 bucket вида https://pub-xxxxx.r2.dev
# Если не задано — карта рендерится белой подложкой (без OSM фона).
# Инструкция по настройке: docs/self-hosted-basemap-setup.md
VITE_BASEMAP_BASE_URL=https://pub-xxxxxxxxxxxxxxxxx.r2.dev
